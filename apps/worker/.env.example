# Worker environment variables
# Copy to .env and fill in values

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/preoracle

# Anthropic API key for verdict generation (Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# The web app's URL — used for CORS allow-list in production
WEB_URL=https://yourdomain.com

# Port the worker listens on (default: 4000)
PORT=4000
